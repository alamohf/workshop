generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  EMPLOYEE
}

enum PayslipStatus {
  PENDING
  DELIVERED
  VIEWED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  MEDICAL_CERTIFICATE
  OTHER
}

// ─── Auth.js required models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Role & Company
  role      UserRole @default(EMPLOYEE)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Subscription
  plan                    Plan      @default(FREE)
  trialEndsAt             DateTime?
  stripeCustomerId        String?   @unique
  stripePriceId           String?
  stripeSubscriptionId    String?   @unique
  stripeCurrentPeriodEnd  DateTime?

  // Auth.js
  accounts  Account[]
  sessions  Session[]

  // PayFlow relations
  payslips           Payslip[]        @relation("EmployeePayslips")
  uploadedPayslips   Payslip[]        @relation("UploaderPayslips")
  documents          Document[]       @relation("EmployeeDocuments")
  reviewedDocuments  Document[]       @relation("ReviewerDocuments")
}

// ─── Company ───────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?  @unique
  logoUrl     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subscription (company-level for admin)
  plan                   Plan      @default(FREE)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripePriceId          String?
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?

  users     User[]
  payslips  Payslip[]
  documents Document[]
}

// ─── Payslip (Contracheque/Holerite) ───────────────────────────────────────

model Payslip {
  id          String        @id @default(cuid())
  companyId   String
  employeeId  String
  uploadedBy  String
  month       Int           // 1-12
  year        Int
  fileUrl     String
  fileName    String
  fileSize    Int?
  status      PayslipStatus @default(PENDING)
  viewedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  User    @relation("EmployeePayslips", fields: [employeeId], references: [id], onDelete: Cascade)
  uploader  User    @relation("UploaderPayslips", fields: [uploadedBy], references: [id])

  @@unique([companyId, employeeId, month, year])
  @@index([companyId])
  @@index([employeeId])
}

// ─── Document (Atestado médico, etc.) ──────────────────────────────────────

model Document {
  id           String         @id @default(cuid())
  companyId    String
  employeeId   String
  reviewedBy   String?
  type         DocumentType   @default(MEDICAL_CERTIFICATE)
  status       DocumentStatus @default(PENDING)
  fileUrl      String
  fileName     String
  fileSize     Int?
  description  String?
  reviewNote   String?
  submittedAt  DateTime       @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee User    @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("ReviewerDocuments", fields: [reviewedBy], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
}
